{
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests{namespace=\"todo-app\"}[5m]))",
          "legendFormat": "ingress requests/sec",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests{namespace=\"todo-app\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(nginx_ingress_controller_requests{namespace=\"todo-app\"}[5m])), 0.001)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nginx_ingress_controller_request_duration_seconds_bucket{namespace=\"todo-app\"}[5m])))",
          "legendFormat": "ingress p95",
          "refId": "A"
        }
      ],
      "title": "Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"todo-app\"})",
          "legendFormat": "restarts",
          "refId": "A"
        }
      ],
      "title": "Pod Restarts",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"todo-app\",container!=\"\"}[5m]))",
          "legendFormat": "cpu cores",
          "refId": "A"
        },
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"todo-app\",container!=\"\"}) / 1024 / 1024 / 1024",
          "legendFormat": "memory GiB",
          "refId": "B"
        }
      ],
      "title": "CPU and Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "kube_ingress_info{namespace=\"todo-app\",ingress=\"todo-ingress\"}",
          "legendFormat": "{{ingress}} {{ingressclass}}",
          "refId": "A"
        }
      ],
      "title": "Ingress Status",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["overkilled-todo", "milestone-3"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "TODO Overview",
  "uid": "todo-overview",
  "version": 1
}
